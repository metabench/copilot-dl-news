# Dependencies
node_modules/
package-lock.json
# Logs
*.log
npm-debug.log*

# Coverage directory used by tools like istanbul
coverage/

# Environment variables
.env
.env.local
.env.test

# Editor directories and files
.vscode/
.idea/
*.swp
*.swo

# OS generated files
.DS_Store
Thumbs.db

# Temporary files
tmp/
temp/

# Build output
dist/
build/

# Production data directory (crawled content)
/data/

# Database artifacts should not be committed from any path by accident.
*.db
*.db-journal
*.db-shm
*.db-wal
*.sqlite
*.sqlite-journal
*.sqlite-shm
*.sqlite-wal
*.sqlite3
*.sqlite3-journal
*.sqlite3-shm
*.sqlite3-wal

# Large NDJSON exports and backups
*.ndjson
gazetteer-backup/

# Migration export artifacts (generated during Phase 0 tooling runs)
migration-export/
migration-export/**/*.ndjson
migration-export/**/*.json
migration-export/**/*.sql

# Migration temp workspace (rewritten on each run)
migration-temp/
migration-temp/**/*.ndjson
migration-temp/**/*.json
migration-temp/**/*.sql

# Data export staging directories
/data/exports/
/data/exports/**/*.ndjson
/data/exports/**/*.json

# Test logs directory (can grow to thousands of files)
testlogs/

# UI review artefacts
# Root screenshots are local/test output by default. Documentation-quality
# screenshots can still be committed intentionally under docs/**/screenshots/.
/screenshots/

# Agent backup archives
.github/agentbackups/

# Local VS Code/playwright runtime artifacts
.playwright-mcp/
.jsgui3-server-cache/
.process-registry.json

# Analysis charts (generated outputs)
build/analysis-charts/

# Generated stylesheets (built from Sass)
src/ui/express/public/ui.css
src/ui/express/public/ui-dark.css
src/ui/express/public/crawler.css

# Generated UI bundles (built via esbuild)
src/ui/express/public/assets/**/*.js

*.db-shm
*.db-wal
*.db
test-failure-summary.json
testlogs/failure-summary.json
test-timing-report.json

package-lock.json

# Root-level temp files (one-off scripts, server outputs)
tmp_*.js
server.err
server.out
server_*.txt

# Data snapshots (inputs/exports used by ad hoc scripts)
data/snapshots/*.json

# Root-level data snapshots (legacy guard)
vnic*.json
remote_vnics.json
sl_backup.json
sl_update.json
all_sl.json
subnets.json

# Deployment artifacts
deploy/artifacts/

# Check HTML outputs (moved to checks/html-outputs/)
/*.check.html
/*.check.json
checks/html-outputs/*.json

# Local/dynamic crawler profiles
tools/crawl/profiles/*.json
!tools/crawl/profiles/local-tiny-monitored-smoke.json
deploy/remote-crawler-v2/remote-*.json

# Local scratchpad and experiment scripts
/scratch/

# bridge runtime files (file-driven command protocol)
tools/dev/agent-bridge/inbox/
tools/dev/agent-bridge/outbox/
tools/dev-bridge/inbox/
tools/dev-bridge/outbox/
tools/dev-bridge/logs/
tools/dev-bridge/state/
