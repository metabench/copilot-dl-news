{
  "description": "Remote/cloud crawl: 10 major news domains x 1000 pages each, with 5-second confirmed local sync and remote payload pruning.",
  "tool": "remote",
  "positionals": [
    "run"
  ],
  "options": {
    "domains": "bbc.com,theguardian.com,reuters.com,nytimes.com,washingtonpost.com,cnn.com,apnews.com,bloomberg.com,ft.com,npr.org",
    "max-pages": 1000,
    "max-concurrent": 10,
    "interval": 5,
    "window": 5,
    "limit": 5,
    "adaptive-limit": true,
    "target-sync-ms": 5000,
    "min-limit": 1,
    "max-limit": 25,
    "prune-after-ingest": true,
    "no-backoff": true
  }
}
